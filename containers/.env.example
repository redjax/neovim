## Base distro image to test on
#  Options: debian:stable-slim, ubuntu:24.04, fedora:41, archlinux:base, alpine:3.21
BASE_IMAGE=debian:stable-slim
## Short tag for naming the container/image (no colons or slashes)
BASE_IMAGE_TAG=debian

## Which Neovim configuration to build/test
#  Options: nvim, nvim-lazyvim, nvim-work, nvim-noplugins, nvim-kickstart
CONFIG_NAME=nvim

# Language runtime versions (Go and Rust are copied from official images;
# Python is installed from the distro's package manager)
GO_IMG_TAG=1.25.5
RUST_IMG_TAG=latest
